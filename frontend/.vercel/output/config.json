{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image$",
			"dest": "_render"
		},
		{
			"src": "^\\/actividades\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/auditoria\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/comisiones\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/cotizaciones\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/cotizaciones\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/empresas\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/empresas\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/eventos\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/eventos\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/facturas\\/nueva\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/facturas\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/facturas\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/login\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/metas\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/pipeline\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/salones\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/servicios\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/tareas\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/usuarios\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/$",
			"dest": "_render"
		}
	]
}